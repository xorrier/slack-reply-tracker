# ──────────────────────────────────────────────
# Slack App Credentials
# Get these from https://api.slack.com/apps → your app → Basic Information
# ──────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# A random string you make up — used for OAuth CSRF protection
# Example: openssl rand -hex 32
SLACK_STATE_SECRET=

# ──────────────────────────────────────────────
# Database
# Get this from Supabase → Project Settings → Database → Connection string (URI)
# ──────────────────────────────────────────────
DATABASE_URL=

# ──────────────────────────────────────────────
# App URL
# During local dev: your ngrok URL (e.g. https://abc123.ngrok-free.app)
# In production: your Railway URL (e.g. https://slack-bot.up.railway.app)
# ──────────────────────────────────────────────
APP_URL=

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3000

# ──────────────────────────────────────────────
# Timezone — do not change
# ──────────────────────────────────────────────
TZ=Asia/Kolkata
